// /usr/local/ufv/ufv-infra/jenkins/Jenkinsfile-infra
pipeline {
    agent any
    
    parameters {
        string(name: 'MY_PUBLIC_IP',       defaultValue: '',                      description: 'Tu IP publica')
        string(name: 'KEY_PAIR_PERSONAL',  defaultValue: 'llave-B',               description: 'Key Pair')
        string(name: 'AWS_REGION',         defaultValue: 'eu-south-2',            description: 'Region')
        choice(name: 'ACTION',             choices: ['deploy', 'destroy'],        description: 'Accion')
        
        // Parámetros dinámicos para los 4 compañeros
        string(name: 'PEER1_VPC', defaultValue: '', description: 'VPC ID Compañero 1')
        string(name: 'PEER1_ACC', defaultValue: '', description: 'Account ID Compañero 1')
        string(name: 'PEER2_VPC', defaultValue: '', description: 'VPC ID Compañero 2')
        string(name: 'PEER2_ACC', defaultValue: '', description: 'Account ID Compañero 2')
        string(name: 'PEER3_VPC', defaultValue: '', description: 'VPC ID Compañero 3')
        string(name: 'PEER3_ACC', defaultValue: '', description: 'Account ID Compañero 3')
        string(name: 'PEER4_VPC', defaultValue: '', description: 'VPC ID Compañero 4')
        string(name: 'PEER4_ACC', defaultValue: '', description: 'Account ID Compañero 4')
    }

    environment {
        AWS_PROFILE_PERSONAL = 'AlumnoB'
        STACK_PERSONAL       = 'stack-personal'
        CFN_PERSONAL         = '/usr/local/ufv/ufv-infra/cloudformation/stack-personal.yaml'
    }

    stages {
        stage('Init') {
            steps {
                script {
                    env.DETECTED_IP = params.MY_PUBLIC_IP != '' ? params.MY_PUBLIC_IP :
                        sh(script: "curl -s https://checkip.amazonaws.com", returnStdout: true).trim() + "/32"
                }
            }
        }

        stage('Deploy Infra') {
            when { expression { params.ACTION == 'deploy' } }
            steps {
                script {
                    def paramsJson = """[
                        {"ParameterKey":"MyPublicIp", "ParameterValue":"${env.DETECTED_IP}"},
                        {"ParameterKey":"KeyPairName", "ParameterValue":"${params.KEY_PAIR_PERSONAL}"},
                        {"ParameterKey":"Peer1VpcId", "ParameterValue":"${params.PEER1_VPC}"},
                        {"ParameterKey":"Peer1AccountId", "ParameterValue":"${params.PEER1_ACC}"},
                        {"ParameterKey":"Peer2VpcId", "ParameterValue":"${params.PEER2_VPC}"},
                        {"ParameterKey":"Peer2AccountId", "ParameterValue":"${params.PEER2_ACC}"},
                        {"ParameterKey":"Peer3VpcId", "ParameterValue":"${params.PEER3_VPC}"},
                        {"ParameterKey":"Peer3AccountId", "ParameterValue":"${params.PEER3_ACC}"},
                        {"ParameterKey":"Peer4VpcId", "ParameterValue":"${params.PEER4_VPC}"},
                        {"ParameterKey":"Peer4AccountId", "ParameterValue":"${params.PEER4_ACC}"}
                    ]"""
                    writeFile file: '/tmp/params-personal.json', text: paramsJson
                    
                    sh """
                        aws cloudformation deploy \
                            --stack-name ${STACK_PERSONAL} \
                            --template-file ${CFN_PERSONAL} \
                            --parameter-overrides file:///tmp/params-personal.json \
                            --capabilities CAPABILITY_IAM CAPABILITY_NAMED_IAM \
                            --region ${params.AWS_REGION} --profile ${AWS_PROFILE_PERSONAL}
                    """
                }
            }
        }

        // --- NUEVA ETAPA PARA DESTRUIR ---
        stage('Destroy Infra') {
            when { expression { params.ACTION == 'destroy' } }
            steps {
                sh "aws cloudformation delete-stack --stack-name ${STACK_PERSONAL} --region ${params.AWS_REGION} --profile ${AWS_PROFILE_PERSONAL}"
                echo "Orden de destrucción enviada a AWS. El proceso tardará unos minutos."
            }
        }
    }
}
